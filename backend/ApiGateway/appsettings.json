{
  "ReverseProxy": {
    "Routes": {
      "bookingRoute": {
        "ClusterId": "bookingCluster",
        "Match": {
          "Path": "/booking/{**catch-all}"
        }
      },
      "userRoute": {
        "ClusterId": "userCluster",
        "Match": {
          "Path": "/user/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/user"
          }
        ]
      }
    },
    "Clusters": {
      "bookingCluster": {
        "Destinations": {
          "bookingService": {
            "Address": "http://localhost:5236/"
          }
        }
      },
      "userCluster": {
        "Destinations": {
          "userService": {
            "Address": "http://localhost:5098/"
          }
        }
      }
    }
  }
}