{
  "ReverseProxy": {
    "Routes": {
      "bookingRoute": {
        "ClusterId": "bookingCluster",
        "Match": {
          "Path": "/booking/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "bookingCluster": {
        "Destinations": {
          "bookingService": {
            "Address": "http://booking-service:5001/"
          }
        }
      }
    }
  }
}